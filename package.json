{
  "name": "dataviz-pro",
  "version": "1.0.0",
  "private": true,
  "description": "Galactic Data Dashboard — Senior-level data visualization showcase",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm run dev -w packages/server",
    "dev:client": "npm run dev -w packages/client",
    "build": "npm run build -w packages/server && npm run build -w packages/client",
    "storybook": "npm run storybook -w packages/client",
    "build-storybook": "npm run build-storybook -w packages/client",
    "lint": "eslint packages/*/src --ext .ts,.tsx",
    "typecheck": "tsc --build",
    "chromatic": "npx chromatic"
  },
  "devDependencies": {
    "chromatic": "^16.0.0",
    "concurrently": "^8.2.2",
    "typescript": "^5.4.5"
  }
}
